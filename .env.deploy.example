# Deploy-time env for the "dev" environment (Raspberry Pi) — used by
# docker-compose.app.yml. Copy to `.env.deploy` on the Pi (gitignored).
#
# Two kinds of value below:
#   • SECRETS — injected by the GitHub Actions workflow from repo Secrets; you do
#     NOT hand-write them into .env.deploy. The workflow writes/exports them.
#   • CONFIG — non-secret, environment-specific (URLs, CORS). Safe to commit here
#     as the example; set the real values in .env.deploy on the Pi.
#
# This file is NOT used on the Mac. Local dev uses apps/backend/.env (DBs by IP).

# ── SECRETS (provided by CI / GitHub Secrets) ─────────────────────────────────
# Same Postgres password the infra compose uses.
POSTGRES_PASSWORD=
# openssl rand -hex 32
JWT_SECRET=
COOKIE_SECRET=
# Publishable API key of the Default Sales Channel (admin → Settings → API Keys).
# Inlined into the web client bundle at build time.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_...

# ── CONFIG (non-secret, dev environment) ──────────────────────────────────────
# Public URL of the Medusa backend (API + admin at /app), via Cloudflare Tunnel.
MEDUSA_BACKEND_URL=https://mds.dev.pandabeer.es
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://mds.dev.pandabeer.es
# Public URL of the storefront.
MEDUSA_STOREFRONT_URL=https://dev.pandabeer.es

# CORS allowlists. STORE_CORS = storefront origin; ADMIN_CORS = admin origin
# (the backend host itself, since the admin is served from it); AUTH_CORS = both.
STORE_CORS=https://dev.pandabeer.es
ADMIN_CORS=https://mds.dev.pandabeer.es
AUTH_CORS=https://dev.pandabeer.es,https://mds.dev.pandabeer.es
