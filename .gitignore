# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (pnpm workspaces)
/node_modules
/apps/*/node_modules

# testing
/coverage

# next.js
/.next/
/out/
apps/*/.next/
apps/*/out/
apps/*/build/

# production
/build

# misc
.DS_Store
*.pem
skills-lock.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.medusa/

# Medusa local file uploads (binaries uploaded from the admin; mutable state, do not version)
apps/backend/static/

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.deploy.example
!apps/*/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# agents (local-only tooling; the docs AGENTS.md / design.md / CLAUDE.md are versioned)
.venv/
.agents/