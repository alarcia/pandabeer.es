# Storefront (Next.js) → Medusa backend
#
# Copia este fichero a .env.local y rellena la publishable key.
# .env.local está gitignored; .env.example se commitea como referencia.

# URL del backend Medusa.
# Local/dev: el backend corre en el Mac; las DB están en la Raspberry.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key del sales channel por defecto.
# Se crea en el admin: Settings → Publishable API Keys. Empieza por "pk_".
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_...
