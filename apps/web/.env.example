# Storefront (Next.js) → Medusa backend
#
# Copy this file to .env.local and fill in the publishable key.
# .env.local is gitignored; .env.example is committed as a reference.

# Medusa backend URL.
# Local/dev: the backend runs on the Mac; the DBs live on the Raspberry Pi.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key of the default sales channel.
# Created in the admin: Settings → Publishable API Keys. Starts with "pk_".
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_...
