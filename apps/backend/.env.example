# Local & dev: Raspberry Pi Docker containers
# Production: Neon (postgres) + Upstash (redis)
DATABASE_URL=postgres://pandabeer:<DB_PASSWORD>@<RASPBERRY_IP>:5432/pandabeer_medusa
# Set to "true" only when Postgres has no SSL (e.g. local Pi). Leave unset in production (Neon).
DATABASE_SSL_DISABLED=true
REDIS_URL=redis://<RASPBERRY_IP>:6379
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:3000,http://localhost:9000
# Generate strong random values (e.g. `openssl rand -hex 32`). Do NOT commit real secrets.
JWT_SECRET=<GENERATE_A_RANDOM_SECRET>
COOKIE_SECRET=<GENERATE_A_RANDOM_SECRET>
WORKER_MODE=shared
ADMIN_DISABLED=false
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_STOREFRONT_URL=http://localhost:3000
